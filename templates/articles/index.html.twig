{% extends 'base.html.twig' %}

{% block title %}Liste des tâches{% endblock %}

{% block body %}
<h1>📝 Liste des tâches</h1>

<a href="{{ path('app_tache_ajouter') }}" class="btn btn-primary mb-3">Ajouter une tâche</a>

{% if taches is empty %}
    <p>Aucune tâche pour le moment.</p>
{% else %}
    <ul>
        {% for tache in taches %}
            <li>
                <a href="{{ path('app_tache_detail', {'id': tache.id}) }}">
                    {% if tache.terminee %}<s>{% endif %}
                    {{ tache.titre }}
                    {% if tache.terminee %}</s>{% endif %}
                </a>
                {% if not tache.terminee %}
                    — <a href="{{ path('app_tache_terminer', {'id': tache.id}) }}">Terminer</a>
                {% endif %}
            </li>
        {% endfor %}
    </ul>
{% endif %}
{% endblock %}