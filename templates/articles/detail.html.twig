{% extends 'base.html.twig' %}

{% block title %}{{ article.titre }}{% endblock %}

{% block body %}

<h1 class="display-4">{{ article.titre }}</h1>

<p class="text-muted mb-4 pb-2 border-bottom">
    Par <strong>{{ article.auteur }}</strong>
    — {{ article.dataCreation|date('d/m/Y à H:i') }}

    {% if article.publie %}
        <span>✅ Publié</span>
    {% else %}
        <span>📝 Brouillon</span>
    {% endif %}
</p>

<div>
    {{ article.contenu }}
</div>

<br>

<a href="{{ path('app_articles') }}">
    ← Retour à la liste
</a>

{% endblock %}