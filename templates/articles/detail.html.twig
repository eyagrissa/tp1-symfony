{% extends 'base.html.twig' %}

{% block title %}{{ tache.titre }}{% endblock %}

{% block body %}
<h1>{{ tache.titre }}</h1>
<p>{{ tache.description }}</p>
<p>Date de création : {{ tache.dateCreation|date('d/m/Y à H:i') }}</p>
<p>Statut : 
    {% if tache.terminee %}
        ✅ Terminé
    {% else %}
        📝 En cours
    {% endif %}
</p>

<a href="{{ path('app_taches') }}">← Retour à la liste</a>
{% endblock %}